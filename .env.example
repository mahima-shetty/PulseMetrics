# Database
DATABASE_URL=postgresql://founder:founder_secret@localhost:5432/founderdashboard

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / LLM (OpenAI or Groq)
# For OpenAI:
OPENAI_API_KEY=sk-your-openai-key
LLM_MODEL=gpt-4o-mini

# For Groq (takes priority if set):
GROQ_API_KEY=gsk-your-groq-api-key
# Optional: override model (default: llama-3.1-8b-instant)
# LLM_MODEL=llama-3.1-70b-versatile
# LLM_MODEL=mixtral-8x7b-32768

# LLM_BASE_URL=  # only for custom OpenAI-compatible endpoints
# CORS
CORS_ORIGINS=http://localhost:3000
